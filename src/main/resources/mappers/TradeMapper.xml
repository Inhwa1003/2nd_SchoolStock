<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.school.schoolstock.domain.trade.repository.TradeRepository">

    <!-- 주문 매칭 완료 거래내역 추가 -->
    <insert id="setMatchedOrder" parameterType="com.school.schoolstock.domain.trade.vo.Trade">
        INSERT INTO trade ( trade_date, buy_order_no, sell_order_no )
        VALUES ( NOW(), #{buyOrderNo}, #{sellOrderNo} )
    </insert>

</mapper>